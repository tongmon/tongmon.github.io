{
  "name": "tongmon.github.io",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "npm run content:generate && vite",
    "content:generate": "tsx scripts/generate-post-manifest.ts",
    "build": "npm run content:generate && tsc --noEmit && vite build && node ./scripts/prepare-pages-build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run eslint && npm run stylelint",
    "eslint": "eslint . --cache",
    "stylelint": "stylelint \"**/*.css\" --cache",
    "format:test": "oxfmt --check \"**/*.{ts,tsx,css}\"",
    "format:write": "oxfmt --write \"**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/spotlight": "^9.0.1",
    "@tabler/icons-react": "^3.41.1",
    "framer-motion": "^12.38.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.4",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-config-mantine": "^4.0.3",
    "oxfmt": "^0.42.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.20.6",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.0"
  }
}
